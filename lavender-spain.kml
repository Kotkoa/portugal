<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Lavender Locations in Spain</name>
    <description>Lavender fields, farms, distilleries, shops and nurseries across Spain. Bloom season: late June — mid July.</description>

    <!-- Styles by category -->
    <Style id="lavender-field">
      <IconStyle>
        <color>ffcc33cc</color>
        <scale>1.3</scale>
        <Icon><href>http://maps.google.com/mapfiles/kml/paddle/purple-stars.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="lavender-farm">
      <IconStyle>
        <color>ffcc33cc</color>
        <scale>1.1</scale>
        <Icon><href>http://maps.google.com/mapfiles/kml/paddle/purple-circle.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="lavender-oil">
      <IconStyle>
        <color>ff9933cc</color>
        <scale>1.0</scale>
        <Icon><href>http://maps.google.com/mapfiles/kml/paddle/ltblu-circle.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="lavender-shop">
      <IconStyle>
        <color>ff9966cc</color>
        <scale>0.9</scale>
        <Icon><href>http://maps.google.com/mapfiles/kml/paddle/pink-circle.png</href></Icon>
      </IconStyle>
    </Style>

    <!-- ========================== -->
    <!-- BRIHUEGA, GUADALAJARA — Lavender Capital of Spain -->
    <!-- ========================== -->

    <Placemark>
      <name>💜 Campos de Lavanda — Main Fields (2,503 reviews)</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 4.7 | 2,503 reviews | MUST-VISIT

The most famous lavender fields in Spain. Brihuega is known as the "Spanish Provence." Endless purple fields on the Alcarria plateau. Best time: last 2 weeks of June — first week of July. Annual Lavender Festival in July.

📍 CM-2005, 19400 Brihuega, Guadalajara]]></description>
      <Point><coordinates>-2.8499762,40.7898494,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>💜 Campos de Lavanda — Second Field (505 reviews)</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 4.7 | 505 reviews

Another lavender field location in Brihuega, closer to the town center. A less crowded alternative to the main fields.

📍 Q467+RX, 19400 Brihuega, Guadalajara]]></description>
      <Point><coordinates>-2.8850287,40.7620315,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🧪 Destilería Jardín de la Alcarria (317 reviews)</name>
      <styleUrl>#lavender-oil</styleUrl>
      <description><![CDATA[⭐ 4.5 | 317 reviews | DISTILLERY

Lavender essential oil distillery. Guided tours showing the steam distillation process. Shop with essential oils, soaps and lavender cosmetics.

📍 Pl. Sector el Alto, 25T, 19400 Brihuega, Guadalajara]]></description>
      <Point><coordinates>-2.8788345,40.7601562,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🛍️ Alcarria Natura — El Rincón de la Lavanda</name>
      <styleUrl>#lavender-shop</styleUrl>
      <description><![CDATA[⭐ 4.8 | 25 reviews | SHOP / MUSEUM

Lavender shop-museum in the center of Brihuega. Lavender products: oils, honey, cosmetics. Information about cultivation and processing.

📍 C. Mayor, 8, 19400 Brihuega, Guadalajara]]></description>
      <Point><coordinates>-2.86989,40.75979,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🍦 Esencias de Vida — Lavender Ice Cream (73 reviews)</name>
      <styleUrl>#lavender-shop</styleUrl>
      <description><![CDATA[⭐ 4.9 | 73 reviews | OIL + GASTRONOMY

Handcrafted lavender oil and artisan lavender ice cream. A unique gastronomic experience.

📍 C. Ntra. Sra. de la Peña, 2, 19400 Brihuega, Guadalajara]]></description>
      <Point><coordinates>-2.8705301,40.7588418,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🎨 Campos de Oro Azul — Workshop</name>
      <styleUrl>#lavender-shop</styleUrl>
      <description><![CDATA[⭐ 4.1 | 34 reviews | WORKSHOP

Lavender product workshop and shop. "Blue Gold" is what lavender is called in Alcarria.

📍 C. las Armas, 21, 19400 Brihuega, Guadalajara]]></description>
      <Point><coordinates>-2.86976,40.760748,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>💜 Campos de Lavanda Hontanares</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 4.5 | 11 reviews | FIELDS

Lavender fields in the Hontanares area, north of Brihuega. Less well-known, quieter for photography.

📍 19413 Brihuega, Guadalajara]]></description>
      <Point><coordinates>-2.7725542,40.8519049,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>💜 Campo de Lavanda El Marañal</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 5.0 | 1 review | FIELDS

Lavender fields near the village of Caspueñas, south of Brihuega. A less touristy location.

📍 GU-908, 19412 Caspueñas, Guadalajara]]></description>
      <Point><coordinates>-2.9844219,40.6973613,0</coordinates></Point>
    </Placemark>

    <!-- ========================== -->
    <!-- TIEDRA, VALLADOLID -->
    <!-- ========================== -->

    <Placemark>
      <name>💜 Tiedra de Lavanda — Farm Museum (940 reviews)</name>
      <styleUrl>#lavender-farm</styleUrl>
      <description><![CDATA[⭐ 4.5 | 940 reviews | FARM MUSEUM

The largest lavender farm in Castilla y León. Guided tours, tastings, shop. Over 100,000 lavender bushes. Open for visits from May to September. Beautiful sunsets over the fields.

📍 47870 Tiedra, Valladolid]]></description>
      <Point><coordinates>-5.263734599999999,41.65667759999999,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>💜 Campos de lavanda Tiedra (91 reviews)</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 4.6 | 91 reviews | FIELDS

Lavender fields next to the Tiedra farm museum. Open access for photography.

📍 VA-VP-6605, 47870 Tiedra, Valladolid]]></description>
      <Point><coordinates>-5.2610332,41.6577829,0</coordinates></Point>
    </Placemark>

    <!-- ========================== -->
    <!-- BURGOS -->
    <!-- ========================== -->

    <Placemark>
      <name>💜 Campos de Lavanda Caleruega (57 reviews)</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 4.8 | 57 reviews | FIELDS

Lavender fields near the town of Caleruega, birthplace of Saint Dominic. Beautiful views of the medieval monastery.

📍 Caleruega, 09451, Burgos]]></description>
      <Point><coordinates>-3.4909258,41.8380458,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>💜 Campos de lavanda Cilleruelo de Arriba</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 4.6 | 19 reviews | FIELDS

Lavender fields in the province of Burgos. Quiet countryside, great photo spots.

📍 09349 Cilleruelo de Arriba, Burgos]]></description>
      <Point><coordinates>-3.6604066,41.9076093,0</coordinates></Point>
    </Placemark>

    <!-- ========================== -->
    <!-- SOUTH AND EAST -->
    <!-- ========================== -->

    <Placemark>
      <name>🧪 Fábrica de esencias Peñarrubia (133 reviews)</name>
      <styleUrl>#lavender-oil</styleUrl>
      <description><![CDATA[⭐ 4.6 | 133 reviews | ESSENTIAL OIL PRODUCTION

Essential oil factory in Ossa de Montiel, Albacete. Near the Lagunas de Ruidera natural park. Guided tours, aroma tastings.

📍 Camino de Santiago, 02611 Ossa de Montiel, Albacete]]></description>
      <Point><coordinates>-2.7496925,38.9535002,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>💜 Campos de Lavanda de Zaén, Murcia</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 4.9 | 9 reviews | FIELDS

Lavender fields in the mountains of Moratalla, Murcia region. A little-known location with wild lavender on mountain slopes.

📍 RM-702, 30441 Moratalla, Murcia]]></description>
      <Point><coordinates>-2.1065238,38.1994345,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🧪 Aceites Esenciales Labiatae, Granada</name>
      <styleUrl>#lavender-oil</styleUrl>
      <description><![CDATA[⭐ 4.7 | 21 reviews | ESSENTIAL OIL PRODUCTION

Lavender essential oil production in the Sierra Nevada mountains. Ecological production, organic lavender.

📍 C. Eras del Molino, 3, 18192 Quéntar, Granada]]></description>
      <Point><coordinates>-3.4618583,37.1940572,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🌿 Finca Las Coronas, Sevilla (61 reviews)</name>
      <styleUrl>#lavender-farm</styleUrl>
      <description><![CDATA[⭐ 4.9 | 61 reviews | FARM

Agricultural farm in Carmona, Seville. Growing lavender and aloe vera. Tours, natural product shop.

📍 Cortijo del Coto, 41410 Carmona, Sevilla]]></description>
      <Point><coordinates>-5.6371293,37.5783348,0</coordinates></Point>
    </Placemark>

    <!-- ========================== -->
    <!-- CATALONIA AND VALENCIA -->
    <!-- ========================== -->

    <Placemark>
      <name>🌿 Aromes de can Rosselló, Lleida</name>
      <styleUrl>#lavender-farm</styleUrl>
      <description><![CDATA[⭐ 4.0 | 30 reviews | AROMATIC PLANT FARM

Aromatic plant farm in Lleida. Growing lavender, rosemary, thyme. Tours and workshops.

📍 Partida Sot de Fontanet, 25, 25197 Lleida]]></description>
      <Point><coordinates>0.62127,41.59691,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🛍️ Lavanda Experience, Barcelona</name>
      <styleUrl>#lavender-shop</styleUrl>
      <description><![CDATA[⭐ 4.8 | 21 reviews | SHOP / EXPERIENCE

Lavender showroom-shop in Sant Cugat (Barcelona). Lavender products, soap and cosmetics workshops.

📍 Av Vía Augusta 2-14, 08174 Sant Cugat del Vallès, Barcelona]]></description>
      <Point><coordinates>2.0535039,41.4842605,0</coordinates></Point>
    </Placemark>

    <Placemark>
      <name>🌿 TheOriginalGarden, Valencia (315 reviews)</name>
      <styleUrl>#lavender-farm</styleUrl>
      <description><![CDATA[⭐ 4.5 | 315 reviews | NURSERY

Aromatic and Mediterranean plant nursery in Miramar, Valencia. Wide selection of lavender, rosemary and sage varieties. Seedlings available for purchase.

📍 Carrer dels Torners, 46714 Miramar, Valencia]]></description>
      <Point><coordinates>-0.1461566,38.9473568,0</coordinates></Point>
    </Placemark>

    <!-- ========================== -->
    <!-- OTHER REGIONS -->
    <!-- ========================== -->

    <Placemark>
      <name>💜 Campos de Lavanda El Romeral, Toledo</name>
      <styleUrl>#lavender-field</styleUrl>
      <description><![CDATA[⭐ 3.6 | 25 reviews | FIELDS

Lavender fields in the province of Toledo, La Mancha. Near the windmills of Consuegra — combine both visits.

📍 45770 El Romeral, Toledo]]></description>
      <Point><coordinates>-3.4373488,39.6975676,0</coordinates></Point>
    </Placemark>


<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Pego → Leiria Road Trip (April 4, 2026)</name>
    <description>Family EV road trip across Spain and Portugal. 990 km scenic southern route through Sierra de Guadalupe mountains, Roman ruins of Merida, and UNESCO fortress town of Elvas. 5 fast-charging stops (50-200kW), 7 photo viewpoints, medieval castles, mountain reservoirs, and a beautiful border crossing into Portugal.</description>

    <!-- Styles -->
    <Style id="charging">
      <IconStyle>
        <color>ff00ff00</color>
        <scale>1.2</scale>
        <Icon><href>http://maps.google.com/mapfiles/kml/paddle/grn-circle.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="scenic">
      <IconStyle>
        <color>ff0080ff</color>
        <scale>1.0</scale>
        <Icon><href>http://maps.google.com/mapfiles/kml/paddle/ylw-stars.png</href></Icon>
      </IconStyle>
    </Style>
    <Style id="start-end">
      <IconStyle>
        <color>ff0000ff</color>
        <scale>1.4</scale>
        <Icon><href>http://maps.google.com/mapfiles/kml/paddle/red-circle.png</href></Icon>
      </IconStyle>
    </Style>

    <!-- Route Line Style -->
    <Style id="routeLine">
      <LineStyle>
        <color>ff0066ff</color>
        <width>4</width>
      </LineStyle>
    </Style>

